# Gmail credentials for the Submit mail server (server/index.js).
# GMAIL_APP_PASSWORD is a 16-char Google "App Password" — NOT your normal
# password. Generate it at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification enabled on the account).
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Optional
# SUBMIT_TO=where-submissions-go@example.com
# PORT=3001
